# Compatibilidade com a configuração anterior do catálogo de brindes.
NEXT_PUBLIC_GIFTS_DESTINATION_URL=
ADMIN_EMAIL=admin@lealbrinde.local
ADMIN_PASSWORD=replace-before-seeding
EMAIL_DELIVERY_MODE=console
PIX_PROVIDER=mock
MOCK_PAYMENT_WEBHOOK_SECRET=replace-with-a-random-development-secret
UPLOAD_PROVIDER=local
FILE_SCANNER_MODE=mock-signature
ALLOW_DRAFT_CHECKOUT=false
# Contrato v2 com a payment_api. Use a mesma chave ADMIN_API_KEY configurada nela.
PAYMENT_API_URL=http://localhost:3001
PAYMENT_API_KEY=
# Deve ser igual a LEALBRINDE_WEBHOOK_SECRET na payment_api.
PAYMENT_API_WEBHOOK_SECRET=
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=
MEDIA_HOSTS=
# Upload administrativo de imagens em produção. Em desenvolvimento, o fallback é public/images/catalog.
PRODUCT_MEDIA_DIRECTORY=
PRODUCT_MEDIA_PUBLIC_BASE_URL=

# Nova API autoritativa NestJS / Cloud Run. Enquanto ausente, o runtime legado local continua ativo.
LEALBRINDE_API_URL=http://localhost:8080
LEALBRINDE_SITE_API_KEY=replace-with-at-least-16-characters

